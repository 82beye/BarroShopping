{
  "name": "shortsgen",
  "version": "0.1.0",
  "private": true,
  "description": "바로쇼핑(ShortsGen) — e커머스 상품 → 쇼핑 쇼츠 자동 생성·다채널 발행 모노레포",
  "scripts": {
    "render": "pnpm --filter @shortsgen/render render",
    "render:props": "pnpm --filter @shortsgen/render render:props",
    "studio": "pnpm --filter @shortsgen/render studio",
    "still": "pnpm --filter @shortsgen/render still",
    "smoke": "pnpm --filter @shortsgen/render smoke",
    "typecheck": "pnpm -r --if-present typecheck",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4"
  }
}
