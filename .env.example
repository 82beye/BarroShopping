# === 바로쇼핑(ShortsGen) 환경변수 예시 ===
# 실제 값은 .env 에만 두고 절대 커밋하지 않는다 (CLAUDE.md §4 / PRD §11 보안).
# 운영 머신(VPS)에서만 실제 키를 채운다.

# --- DB (P2-2) ---
DATABASE_URL=postgresql://user:password@localhost:5432/shortsgen

# --- 스크립트 생성 (FR-2): Claude Code 스킬(shorts-script) 사용 → API 키 불필요 ---

# --- 음성/TTS (FR-3) ---
ELEVENLABS_API_KEY=

# --- 쿠팡 파트너스 OpenAPI (P2-7 상품데이터·deeplink) ---
COUPANG_ACCESS_KEY=
COUPANG_SECRET_KEY=

# --- 발행: YouTube (FR-8, D2 1순위) ---
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# --- 발행: Instagram / TikTok (후순위) ---
INSTAGRAM_ACCESS_TOKEN=
TIKTOK_ACCESS_TOKEN=

# --- 알림 (FR-10) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- 운영 가드레일 (PRD §11) ---
DAILY_QUOTA=30
